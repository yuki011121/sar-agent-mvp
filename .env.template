# SAR Multi-Agent System Environment Configuration Template
# 复制此文件为 .env 并填入你的API密钥

# =============================================================================
# LLM API Keys (至少需要配置一个)
# =============================================================================

# OpenAI API Key (用于Interview Agent和History Agent)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (用于Health Agent, Path Analysis, Logistics Agents)
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here  # Health Agent使用此变量名

# 通用API Key (Path Analysis Agent使用)
API_KEY=your_gemini_api_key_here

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# 选择默认LLM提供商: "google" 或 "openai"
LLM_PROVIDER=google

# Gemini模型配置
GEMINI_DEFAULT_MODEL=gemini-1.5-flash

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis连接URL
REDIS_URL=redis://localhost:6379

# =============================================================================
# Agent Configuration
# =============================================================================

# Weather Agent配置
LATITUDE=35.2828
LONGITUDE=-120.6596
UPDATE_INTERVAL_SECONDS=3600
HTTP_TIMEOUT=30

# Photo Analysis Agent配置
IMAGE_INPUT_DIR=input_images
REDIS_OUTPUT_STREAM=photo.analysis.raw
YOLO_MODEL_PATH=yolov8m.pt
MAX_RETRIES=3
RETRY_DELAY=5

# Path Analysis Agent配置
AGENT_NAME=path-analysis-agent
AGENT_VERSION=1.1
DEM_PATH=agents/path_analysis/data/slo_dem.tif
START_LON=-120.6605
START_LAT=35.2980
TOP_K=3
DO_VISUALIZE=true

# Health Agent配置
UPDATE_INTERVAL_SECONDS=60

# Logistics Agent配置
UPDATE_INTERVAL_SECONDS=1800

# =============================================================================
# Storage Configuration
# =============================================================================

# MinIO配置
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9000

# =============================================================================
# System Configuration
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 工作目录
WORKSPACE_PATH=/workspace

# Docker网络
DOCKER_NETWORK=sar-network